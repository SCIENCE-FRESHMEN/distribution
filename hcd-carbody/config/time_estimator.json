{
  // 时间估计器模型配置文件
  // 用于预测堆垛机完成任务所需的时间
  
  "model_path": "estimate/model/estimator_model_residual_models.pkl",  // 训练好的时间估计模型文件路径
  
  // 堆垛机基础操作时间配置（单位：秒）
  "pickup_time_default": 25.0,  // 堆垛机取货操作默认耗时（秒）
  "drop_time_default": 25.0,    // 堆垛机放置货物操作默认耗时（秒）
  
  // 入库和出库口列位置定义（作为默认值，当dock_map_in/out中未定义具体列时使用）
  "dock_in_col": 1,     // 默认入库口所在的列号
  "dock_out_col": 17,   // 默认出库口所在的列号
  
  // 入库口位置映射表（用于定位入库口坐标）
  "dock_map_in": {
    "L1C17": { "col": 17, "level": 1 },  // 第一层第17列的入库口
    "L2C17": { "col": 17, "level": 2 },  // 第二层第17列的入库口
    "L4C1": { "col": 1, "level": 4 }     // 第四层第1列的入库口
  },  // 入库口位置定义（L表示层数，C表示列数）
  
  // 出库口位置映射表（用于定位出库口坐标）
  "dock_map_out": {
    "L1C1": { "col": 1, "level": 1 },   // 第一层第1列的出库口
    "L1C17": { "col": 17, "level": 1 }, // 第一层第17列的出库口
    "L2C1": { "col": 1, "level": 2 },   // 第二层第1列的出库口
    "L2C17": { "col": 17, "level": 2 }, // 第二层第17列的出库口
    "L3C17": { "col": 17, "level": 3 }  // 第三层第17列的出库口
  },  // 出库口位置定义（L表示层数，C表示列数）
  
  // 堆垛机物理参数配置
  "physics": {
    // 尺寸参数
    "col_scale": 6.0,      // 每列之间的距离（单位：米）
    "layer_scale": 2.6,    // 每层之间的高度（单位：米）
    
    // 速度参数（单位：米/秒）
    "v_col_max": 2,        // 堆垛机水平移动的最大速度
    "v_layer_max": 0.5,    // 堆垛机垂直移动的最大速度
    
    // 加速度参数（单位：米/秒²）
    "a_col": 0.4,          // 堆垛机水平移动的最大加速度
    "a_layer": 0.1         // 堆垛机垂直移动的最大加速度
  }  // 堆垛机物理运动参数（建议通过实际测量后调整）
}