{
  // 车身立体库系统配置文件
  // 定义仓库布局、生产流程和调度算法参数

  // 基础设施配置
  "num_aisles": 4,  // 立体库巷道数量（即货架通道数量）
  "num_production_lines": 4,  // 对接的生产产线数量

  // 巷道与产线映射关系
  "aisle_production_line_mapping": {
    "1": [1, 2, 3, 4],  // 巷道1可以服务的产线：产线1-4
    "2": [1, 2, 3, 4],  // 巷道2可以服务的产线：产线1-4
    "3": [1, 2, 3, 4],  // 巷道3可以服务的产线：产线1-4
    "4": [1, 2, 3, 4]   // 巷道4可以服务的产线：产线1-4
  },  // 每个巷道可以服务的生产产线列表

  // 标准货架尺寸配置（当特定巷道未指定尺寸时使用这些值）
  "num_rows": 2,      // 排（1/2分别表示左/右）
  "num_columns": 17,  // 总列数
  "num_levels": 5,    // 总层数（如未设置aisle_dimensions，则作为每个巷道的默认标准）

  // 特定巷道尺寸配置（会覆盖标准尺寸配置）
  "aisle_dimensions": {
    "1": { "rows": 2, "columns": 17, "levels": 5 },  // 巷道1：2排×17列×5层
    "2": { "rows": 2, "columns": 17, "levels": 5 },  // 巷道2：2排×17列×5层
    "3": { "rows": 2, "columns": 17, "levels": 5 },  // 巷道3：2排×17列×5层
    "4": { "rows": 2, "columns": 11, "levels": 5 }   // 巷道4：2排×11列×5层（列数与其他巷道不同）
  },  // 各巷道的具体尺寸（排、列、层），如果设置了该参数，会覆盖上面num_rows、num_columns、num_levels的默认值

  // 巷道禁用条件配置（限制某些类型货物存放在特定巷道）
  "aisle_forbidden": {
    "1": {"skid_type":["1", 1]},  // 巷道1禁用：滑橇类型为"1"或1的货物（防止字段类型设置错误，所以同时匹配字符串和整数类型）
    "2": {"skid_type":["1", 1]},  // 巷道2禁用：滑橇类型为"1"或1的货物
    "3": {"skid_type":["1", 1]},  // 巷道3禁用：滑橇类型为"1"或1的货物
    "4": {}                       // 巷道4无禁用条件
  },  // 各巷道的禁用条件（根据货物特性限制存储位置）

  // 仓库容量相关配置
  "total_positions": 620,   //总位置数（只要大于等于真实总数即可，实际会使用aisle_dimensions-disabled_positions得到每个巷道的可用数量）
  "max_beams": 620,   //总beam数（同上）
  "initial_inventory_count": 200,   //初始库存数（仿真需要）
  "use_double_layer": false,  // 是否启用双层货位
  
  // 禁用的货位列表（无法使用的具体货位位置）
  "disabled_positions": ["1-1-01-01","1-1-01-02","1-1-01-03","1-1-01-04","1-1-01-05","2-1-01-01","2-1-01-02","2-1-01-03","2-1-01-04","2-1-01-05","3-1-01-01","3-1-01-02","3-1-01-03","3-1-01-04","3-1-01-05","4-1-01-01","4-1-01-02","4-1-01-03","4-1-01-04","4-1-01-05","1-1-17-01","1-1-17-02","1-1-17-03","1-1-17-04","1-1-17-05","2-1-17-01","2-1-17-02","2-1-17-03","2-1-17-04","2-1-17-05","3-1-17-01","3-1-17-02","3-1-17-03","3-1-17-04","3-1-17-05","4-1-11-01","4-1-11-02","4-1-11-03","4-1-11-04","4-1-11-05"],  //禁用的位置（格式：巷道-排-列-层）
  
  // 特征别名映射（用于处理不同来源的数据字段名称差异）
  "feature_alias": {
    "skid_state": ["skid_state", "滑橇状态", "skidState"],  // 滑橇状态字段的多种表达方式
    "skid_type": ["skid_type", "滑橇类型", "skidType"]       // 滑橇类型字段的多种表达方式
  },  // 滑橇状态和滑橇类型的别名映射，保证对齐算法内部的字段名

  // 时间参数配置（单位：秒）
  "use_magnetic_crane": false,            // 是否使用磁力吊设备
  "outbound_congestion_time": 5.0,        // 出库口平均拥堵时间
  "transport_delay_s": 30.0,              // 入库运输延迟时间（识别入库至到入库口的时间）
  "blockage_time": 15.0,                  // 设备或通道拥堵等待时间
  "magnetic_crane_time": 40.0,            // 磁力吊作业时间

  // 出库匹配特征配置（定义从不同巷道出库时的匹配规则）
  "outbound_match_features": {
    "1": ["rfid"],  // 巷道1出库：使用RFID进行匹配
    "2": ["rfid"],  // 巷道2出库：使用RFID进行匹配
    "3": ["rfid"],  // 巷道3出库：使用RFID进行匹配
    "4": ["rfid"]   // 巷道4出库：使用RFID进行匹配
  },  // 出库匹配特征配置（决定出库时如何匹配货物，可选rfid或输入对应特征字段名，支持多个特征）

  // 调度算法权重参数（用于优化调度性能）
  "lr_balance_weight": 0.1,                          // 左右平衡权重（平衡巷道间负载）
  "makespan_weight": 0.005,                         // 最大完工时间权重（最小化整体完成时间）
  "balance_weight": 0.1,                            // 负载均衡权重（平衡各巷道工作量）
  "production_line_avg_time_weight": 0.05,          // 生产线平均时间权重
  "production_line_balance_weight": 0.1,            // 生产线负载均衡权重
  "aisle_dispersion_weight": 0.001                  // 巷道分散度权重（避免集中于某几个巷道）
} // 立体库系统配置参数